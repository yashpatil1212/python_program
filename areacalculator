#Area Calculator    

print("**********AREA CALCULATOR**********")
while True:
    print("Press 1. to get the Area of Square")
    print("Press 2.to get the Area of Rectangle")
    print("Press 3. to get the  Area of Circle")
    print("press 4. to get the Area of Triangle")
    
    choice=int(input("Enter your choice: "))
    
    if choice==1:
        while True:
            side=float(input("enter the length of one side:"))
            area=side**2
            print("the area of square is ",area)
            repeat=input("do you want to try again with square?")
            if repeat=="no":
                break
    elif  choice==2:
        while True:
            length=float(input("enter the length of the rectangle:"))
            width=float(input("enter the width of the rectangle:"))
            area=length*width
            print("the area of the reactangle is ",area)
            if repeat=="no":
                break
    elif choice==3:
        while True:
            radius =float(input("enter the radius of the circle:"))
            area=((22/7)*(radius**2))
            print("the area of the circle is ",area)
            repeat =input("do you want to try again with circle?")
            if repeat=="no":
                break
    elif choice==4:
        while True:
            base=float(input("enter the base of the tringle:"))
            height=float(input("enter the height of the triangle:"))
            area=0.5*base*height
            print("the area of the tringle is ",area)
            repeat=input("do you want to try again with triangle")
            if repeat=="no":
                break

    repeat1= input("do you want to repeat the menu again?")
    if repeat1=="no":
        break